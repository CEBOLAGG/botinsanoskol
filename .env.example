# Copie este arquivo para .env e preencha os valores.

# --- Discord ---
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# --- Cobalt (self-hosted) ---
COBALT_BASE_URL=http://localhost:9000/
COBALT_API_KEY=

# --- Opcionais ---
MAX_UPLOAD_MB=10
CACHE_TTL_MINUTES=15

# yt-dlp/ffmpeg: por padrao o bot usa os binarios em ./bin.
# Numa VPS Linux, aponte para os instalados no sistema (ou deixe vazio se no PATH):
# YTDLP_PATH=/usr/local/bin/yt-dlp
# FFMPEG_DIR=/usr/bin
